---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contact — Whitney Masulis';
const description = 'Get in touch with Whitney Masulis about service design, complex systems, and interesting problems.';
const canonicalURL = 'https://whitneyesque.github.io/contact.html';
---
<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogType="website"
  pageId="contact"
>
  <section class="contact-hero">
    <span class="section-label">Contact</span>
    <h1>Have a system that's feeling tangled? <em>Let's chat about it.</em></h1>

    <div class="two-col">
      <div class="reveal">
        <p>I'm down for conversations about service design, complex systems, and interesting problems. Whether you're starting something new, improving something existing, or just want to think something through, say hi.</p>
        <p class="contact-note">Currently working at the intersection of AI and AgeTech.</p>

        <a href="mailto:whitney@whitneymasulis.com" class="contact-email">whitney@whitneymasulis.com</a>

        <div class="contact-links">
          <a href="https://www.linkedin.com/in/whitneymasulis/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>

      <aside class="contact-quote-wrap reveal">
        <blockquote class="contact-quote">The best projects start with a real conversation, not an RFP.</blockquote>
      </aside>
    </div>
  </section>

  <div class="contact-bottom-spacer"></div>
</BaseLayout>
