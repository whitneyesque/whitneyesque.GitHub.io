---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '404 — Page Not Found | Whitney Masulis';
const description = 'This page doesn\'t exist, but your curiosity brought you here. Let\'s get you back on track.';
const canonicalURL = 'https://whitneymasulis.com/404.html';
---
<BaseLayout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  ogType="website"
>
  <section class="not-found">
    <div class="not-found__inner reveal">
      <span class="not-found__label">Error</span>
      <h1 class="not-found__code">404</h1>
      <p class="not-found__message">
        This page has wandered off.<br>
        The rest of the site is right where you left it.
      </p>
      <div class="not-found__actions">
        <a href="index.html" class="btn">Back to Home</a>
        <a href="work.html" class="not-found__link">View Work →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-8) var(--sp-4);
    background: var(--warm-white);
  }

  .not-found__inner {
    text-align: center;
    max-width: 520px;
  }

  .not-found__label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--charcoal-soft);
    margin-bottom: var(--sp-2);
  }

  .not-found__code {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(96px, 22vw, 180px);
    line-height: 1;
    color: var(--charcoal);
    letter-spacing: -4px;
    margin-bottom: var(--sp-4);
  }

  .not-found__message {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.65;
    color: var(--charcoal-mid);
    margin-bottom: var(--sp-6);
  }

  .not-found__actions {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .not-found__link {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--charcoal-mid);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .not-found__link:hover {
    color: var(--rust);
    border-color: var(--rust);
  }
</style>
