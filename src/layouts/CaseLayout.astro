---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  client: string;
  year: number;
  role: string;
  team?: string;
  timeline: string;
  tags: string[];
  summary: string;
  hero_image?: string;
  slug: string;
  specimen?: string;
  specimenSignoff?: string;
}

const {
  title, client, year, role, team, timeline, tags, summary,
  hero_image, specimen, slug,
} = Astro.props;

const canonicalURL = `https://whitneyesque.github.io/cases/${slug}.html`;
const pageTitle = `${title} — Whitney Masulis`;

const allPublished = await getCollection('cases', entry => entry.data.status === 'published');
const ordered = allPublished
  .map(entry => ({ slug: entry.slug, title: entry.data.title, year: entry.data.year }))
  .sort((a, b) => b.year - a.year || a.slug.localeCompare(b.slug));
const currentIndex = ordered.findIndex(c => c.slug === slug);
const prev = currentIndex > 0 ? ordered[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < ordered.length - 1 ? ordered[currentIndex + 1] : null;
---
<BaseLayout
  title={pageTitle}
  description={summary}
  canonicalURL={canonicalURL}
  ogType="website"
  pageId="work"
>
  <article class="case-article">

    <header class="case-hero" style={hero_image ? `--hero-image: url('${hero_image}')` : undefined} data-has-image={hero_image ? 'true' : undefined}>
      {specimen && (
        <img
          class="case-hero-specimen"
          src={specimen}
          alt=""
          aria-hidden="true"
          loading="eager"
          decoding="async"
        />
      )}
      <div class="case-hero-inner">
        <a href="/work.html" class="case-back-top">← Work</a>
        <h1 class="case-title" set:html={title} />
        <p class="case-summary">{summary}</p>

        {/* V4 spec: tag pills above the meta cards */}
        <div class="case-hero-tags tag-row">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>

        {/* V4 spec: 3 dark cards (Client / Year / Role) inside the dark hero */}
        <dl class="case-detail-cards">
          <div class="case-detail-card">
            <dt class="case-detail-label">Client</dt>
            <dd class="case-detail-value">{client}</dd>
          </div>
          <div class="case-detail-card">
            <dt class="case-detail-label">Year</dt>
            <dd class="case-detail-value">{year}</dd>
          </div>
          <div class="case-detail-card">
            <dt class="case-detail-label">Role</dt>
            <dd class="case-detail-value">{role}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="case-body">
      <slot />
    </div>

    <nav class="case-nav" aria-label="Case study navigation">
      <div class="case-nav-inner">
        {prev ? (
          <a href={`/cases/${prev.slug}.html`} class="case-nav-link case-nav-prev" rel="prev">
            <span class="case-nav-direction">← Previous case</span>
            <span class="case-nav-title" set:html={prev.title} />
          </a>
        ) : <span class="case-nav-spacer" aria-hidden="true"></span>}

        <a href="/work.html" class="case-nav-allwork">All work</a>

        {next ? (
          <a href={`/cases/${next.slug}.html`} class="case-nav-link case-nav-next" rel="next">
            <span class="case-nav-direction">Next case →</span>
            <span class="case-nav-title" set:html={next.title} />
          </a>
        ) : <span class="case-nav-spacer" aria-hidden="true"></span>}
      </div>
    </nav>

  </article>
</BaseLayout>
