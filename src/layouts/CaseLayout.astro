---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  client: string;
  year: number;
  role: string;
  team?: string;
  timeline: string;
  tags: string[];
  summary: string;
  hero_image?: string;
  slug: string;
  /** Deprecated; ignored. Kept on the interface so existing drafts still typecheck. */
  specimen?: string;
  specimen_alt?: string;
  specimenSignoff?: string;
}

const {
  title, client, year, role, team, timeline, tags, summary,
  hero_image, slug,
} = Astro.props;

const canonicalURL = `https://whitneyesque.github.io/cases/${slug}.html`;
const pageTitle = `${title} — Whitney Masulis`;
---
<BaseLayout
  title={pageTitle}
  description={summary}
  canonicalURL={canonicalURL}
  ogType="website"
  pageId="work"
>
  <article class="case-article">

    <header class="case-hero" style={hero_image ? `--hero-image: url('${hero_image}')` : undefined} data-has-image={hero_image ? 'true' : undefined}>
      <div class="case-hero-inner">
        <a href="/work.html" class="case-back-top">← Work</a>
        <h1 class="case-title" set:html={title} />
        <p class="case-summary">{summary}</p>

        {/* V4 spec: tag pills above the meta cards */}
        <div class="case-hero-tags tag-row">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>

        {/* V4 spec: 3 dark cards (Client / Year / Role) inside the dark hero */}
        <dl class="case-detail-cards">
          <div class="case-detail-card">
            <dt class="case-detail-label">Client</dt>
            <dd class="case-detail-value">{client}</dd>
          </div>
          <div class="case-detail-card">
            <dt class="case-detail-label">Year</dt>
            <dd class="case-detail-value">{year}</dd>
          </div>
          <div class="case-detail-card">
            <dt class="case-detail-label">Role</dt>
            <dd class="case-detail-value">{role}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="case-body">
      <slot />
    </div>

    <footer class="case-footer">
      <a href="/work.html" class="case-back-bottom">← Back to Work</a>
    </footer>

  </article>
</BaseLayout>
