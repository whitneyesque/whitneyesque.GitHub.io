---
/**
 * SpecimenSignoff — Exception 3 in the V3 design system.
 *
 * Optional. Use at most ONCE per case study, at the very end, above the
 * "back to work" link. Functions like a printer's mark or chapter ornament.
 *
 * Pass the same specimen used on the cover, cropped tighter.
 */
interface Props {
  specimen: string;
}
const { specimen } = Astro.props;
---
<div class="specimen-signoff" aria-hidden="true">
  <img src={specimen} alt="" loading="lazy" decoding="async" />
</div>
