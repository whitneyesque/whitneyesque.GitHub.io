---
interface Stat {
  value: string;
  label: string;
}
interface Props {
  stats: Stat[];
  /** 'dark' renders on the charcoal/ink background used at the top of case studies */
  variant?: 'default' | 'dark';
}
const { stats, variant = 'default' } = Astro.props;
---
<div class={`stat-row${variant === 'dark' ? ' stat-row--dark' : ''}`}>
  {stats.map(({ value, label }) => (
    <div class="stat-item">
      <span class="stat-value">{value}</span>
      <span class="stat-label">{label}</span>
    </div>
  ))}
</div>
